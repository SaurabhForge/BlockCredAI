# Backend Environment Variables
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
REQUEST_BODY_LIMIT=100kb
UPLOAD_LIMIT_BYTES=2097152
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
GCP_API_URL=https://YOUR_CLOUD_RUN_SERVICE-REGION.a.run.app

# Blockchain Configuration
BLOCKCRED_CONTRACT_ADDRESS=0x5FbDB2315678afccb333f8a9fcff498e4d4ff826
RPC_URL=http://127.0.0.1:8545
PRIVATE_KEY=your_local_or_deployer_private_key

# AI Service
AI_URL=http://localhost:8001/predict

# Firebase (Optional)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id
