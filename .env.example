# Blockchain
BLOCKCRED_CONTRACT_ADDRESS=0x...
PRIVATE_KEY=your_wallet_private_key
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
RPC_URL=http://127.0.0.1:8545

# Backend
PORT=4000
AI_URL=http://localhost:8001/predict
CORS_ORIGIN=http://localhost:3000
REQUEST_BODY_LIMIT=100kb
UPLOAD_LIMIT_BYTES=2097152
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# GCP / Cloud Run
# After deploying the backend API to Cloud Run, set both values to the HTTPS service URL.
GCP_API_URL=https://YOUR_CLOUD_RUN_SERVICE-REGION.a.run.app

# Firebase
FIREBASE_API_KEY=your_api_key
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_AUTH_DOMAIN=your_auth_domain
FIREBASE_DATABASE_URL=your_database_url
FIREBASE_STORAGE_BUCKET=your_storage_bucket

# IPFS (nft.storage)
NFT_STORAGE_KEY=your_nft_storage_key

# Frontend
NEXT_PUBLIC_CONTRACT_ADDRESS=0x...
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_GCP_API_URL=https://YOUR_CLOUD_RUN_SERVICE-REGION.a.run.app
